# Tanur Agent Configuration — copy to .env and fill in.

# Stellar Testnet
RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Deployed contracts / assets (also read from deploy/addresses.json)
VAULT_CONTRACT=
YIELD_CONTRACT=
TANUR_SAC=
USDC_SAC=

# Oracle signing seed (Stellar secret, S...). Never commit the real .env.
ORACLE_SECRET=

# Gemini AI (free tier: https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Demo: inject a fake price spike so the Gemini gate vetoes it (§6.4)
DEMO_ANOMALY=off

# Run a single oracle cycle then exit (off = loop monthly)
ORACLE_ONCE=on

# Market Analyst (stretch) — closed-loop GORR safety rails
AUTONOMY_MODE=off
MAX_GORR_CHANGE_BPS=100
MIN_GORR_BPS=100
MAX_GORR_BPS=1000
